[Report: HTTP_POST_Download_TRANSPurchase]
  
	Form  				:  HTTP_POST_Download_TRANSPurchase
	
	Plain JSON 			: No
	
	Export Empty Fields	: Yes
		
[Form: HTTP_POST_Download_TRANSPurchase]
	
    Parts 				:  HTTP_POST_Download_TRANSPurchase

	JSONTag				: ""
	
[Part: HTTP_POST_Download_TRANSPurchase]

    Lines				:  HTTP_POST_Download_TRANSPurchase
				
	Scroll				:  Vertical
	
[Line: HTTP_POST_Download_TRANSPurchase]

	Fields 				:  JSONCMPTallyCode_Download_TRANSPurchase,JSONCMPTallyName_Download_TRANSPurchase,+
						   JSONCMPTallySerial_Download_TRANSPurchase,JSONCMPTallyrequesttype_Download_TRANSPurchase
	
[Field: JSONCMPTallyCode_Download_TRANSPurchase]
		
	Set As 				:  $TallyCompanyCode:Company:##SVCurrentCompany
				
	JSONTag				: 	"tallycode"
	
[Field: JSONCMPTallyName_Download_TRANSPurchase]
		
	Set As 				:  $Name:Company:##SVCurrentCompany
				
	JSONTag				: 	"tallyname"
	
[Field: JSONCMPTallySerial_Download_TRANSPurchase]
		
	Set As 				:  $$LicenseInfo:SerialNumber
				
	JSONTag				: 	"tallyserialno"
	
[Field:  JSONCMPTallyrequesttype_Download_TRANSPurchase]
		
	Set As 				:  "Purchase"
				
	JSONTag				: 	"requesttype"

	

	
[System: Formulae]
	
	DownloadSTKRate	: $$TgtObject:##Download_TRANS_productrate / $$TgtObject:##Download_TRANS_unit
	



	
[Function: PurLedgerMasterCreate]
	
	010		: If	: $$IsEmpty:$Name:Ledger:$customername
	020		: NEW OBJECT	: Ledger	
	
	030		:	SET VALUE	: Name					: $$LocaleString:$customername
	040		:	SET VALUE	: Parent				:"Sundry Creditors"
	
	050		:	SET VALUE	: PRIORSTATENAME		: $$LocaleString:""
	060		:	SET VALUE	: COUNTRYNAME			: $$LocaleString:""
	070		:	SET VALUE	: GSTREGISTRATIONTYPE   : $$LocaleString:""
	080		:	SET VALUE	: VATDEALERTYPE         : $$LocaleString:""
	090		:	SET VALUE	: COUNTRYOFRESIDENCE    : $$LocaleString:""
	100		:	SET VALUE	: LEDSTATENAME          : $$LocaleString:""
	180 	:	Set Target:...
	
	190		: Create Target

	200		: End If
