

[Collection: Download_TRANS_URL_Purchase]
	
	Data Source  		: File JSON :@@AmtechPurchaseInvoice 
	
[Collection: Download_TRANS_URL_Purchase2]
	
	;RemoteRequest		: HTTP_POST_Download_TRANSPurchase : UTF8
	JSON Object			: Download_TRANS_Response_pur
	Fetch 				: .*.			
	Client Only			: Yes	
[Object: Download_TRANS_Response_pur]
		
	Collection			: message		: message

[Object: message]

