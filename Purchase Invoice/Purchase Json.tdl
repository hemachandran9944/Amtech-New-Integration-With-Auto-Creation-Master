	Storage				: consigneegstinnumber	: String
	Storage				: invoicevalue			: String
	Storage				: ewaybillno			: String
	Storage				: ewaybillnodate		: String
	
	Collection			: vchproductlist_pur	: vchproductlist_pur
	Collection			: vchledgerlist_pur		: vchledgerlist_pur
	Collection			: Additionalledgerlist	: Additionalledgerlist
	Collection			: Roundoff				: Roundoff
		
[Object: vchproductlist_pur]

	Storage				: invoicenumber 		: String
	Storage				: product				: String
	Storage				: productdescription	: String
	Storage				: parent				: String
