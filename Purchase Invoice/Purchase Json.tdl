	Storage				: requesttype	: String
	Storage				: date			: String
	
	Collection			: purchaselist	: purchaselist
		
[Object: purchaselist]

	Storage				: invoicenumber 		: String
	Storage				: invoicedate			: String
	Storage				: narration				: String
