	652A		: Msg Box	: "652A" 	: ##Download_TRANS_productgroup
	
	652B		: Msg Box	: "652B"	: ##Download_TRANS_productgodown
	
	652C		: Msg Box	:  "652C"	: ##Download_TRANS_productunit
	

	654		: If: (Not($$IsEmpty:##Download_TRANS_STK_product))
	
	657		: INSERT COLLECTION OBJECT				: INVENTORY ENTRIES
	658		: SET VALUE		: StockItemName			: ##Download_TRANS_product
	659A	: SET VALUE		: IsDeemedPositive		: Yes
	659AA	: SET VALUE		: ISLASTDEEMEDPOSITIVE	: Yes
	661		: SET VALUE		: BilledQty				: ($$TgtObject:($$AsQty:##Download_TRANS_productqty)) * 1
	662		: SET VALUE		: Rate					: $$TgtObject:$$AsRate:##Download_TRANS_productrate
	663		: SET VALUE		: Amount				: ($$TgtObject:($$AsAmount:##Download_TRANS_productvalue)) * -1

	664		: INSERT COLLECTION OBJECT				: BATCH ALLOCATIONS
		
	665		: SET VALUE		: GodownName			: if $$IsEmpty:##Download_TRANS_productgodown then "Main Location" else ##Download_TRANS_productgodown
	668		: SET VALUE		: BilledQty				: ($$TgtObject:($$AsQty:##Download_TRANS_productqty)) * 1		
	669		: SET VALUE		: Rate					: ($$TgtObject:($$AsRate:##Download_TRANS_productrate))
	670		: SET VALUE		: Amount				: ($$TgtObject:($$AsAmount:##Download_TRANS_productvalue)) * -1
