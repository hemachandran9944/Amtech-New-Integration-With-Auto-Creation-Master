	674aa	: Walk Collection	: AccCostcentre	
	674b	: SET		: Purchase_CCNAME	: $$LocaleString:$CCNAME	
	674c	: SET		: Purchase_CCAMOUNT : $$LocaleString:$CCAMOUNT	
	
	674d	: INSERT COLLECTION OBJECT		: COSTCENTREALLOCATIONS
	674e	: SET VALUE : NAME				: ##Purchase_CCNAME
	674f	: SET VALUE : AMOUNT 			: $$AsAmount:##Purchase_CCAMOUNT * -1
