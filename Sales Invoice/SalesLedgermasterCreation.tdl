	190		: Create Target

	200		: End If

	
	


[Function: SalesRound_MasterCreation]
	
		

	
    010 : If : NOT $$IsObjectExists:Ledger:##Sales_Round_Off_RoundoffNAME 
	

        020 : NEW OBJECT : Ledger
        030 : SET VALUE  : Name             : $$Localestring:##Sales_Round_Off_RoundoffNAME
        040 : SET VALUE  : Parent           : $$Localestring:##Sales_Round_Off_RoundoffParent
        
        080 : CREATE TARGET
        
    090 : End If
	












