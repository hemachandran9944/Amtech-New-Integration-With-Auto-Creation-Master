[Function: SalesCGST_LedgerCreation]
	

	010		: If	: $$IsEmpty:$Name:Ledger:$Taxledger
	
	020		: NEW OBJECT	: Ledger	
	
	030		: SET VALUE	: Name					: $$LocaleString:"Output  CGST"
	040		: SET VALUE	: Parent				: $$LocaleString:"Duties & Taxes"
	045		: SET VALUE	: TAXTYPE				: $$LocaleString:"GST"
	050		: SET VALUE	: GSTDUTYHEAD			: $$LocaleString:"CGST"
	070		: SET VALUE	: RATEOFTAXCALCULATION  : $$LocaleString:"18"
	180 	: Set Target:...
	190		: Create Target

	200		: End If


[Function: SalesSGST_LedgerCreation]
		

	010		: If	: $$IsEmpty:$Name:Ledger:$Taxledger
	020		: NEW OBJECT	: Ledger

	030		: SET VALUE	: Name					: $$LocaleString:"Output SGST"
	040		: SET VALUE	: Parent				: $$LocaleString:"Duties & Taxes"
	045		: SET VALUE	: TAXTYPE				: $$LocaleString:"GST"
	050		: SET VALUE	: GSTDUTYHEAD			: $$LocaleString:"SGST/UTGST"
	070		: SET VALUE	: RATEOFTAXCALCULATION	: $$LocaleString:"9"
	180		: Set Target	: ...
	190		: Create Target
	200		: End If

	
	
	

[Function: SalesIGST_LedgerCreation]
	
	010		: If	: $$IsEmpty:$Name:Ledger:$Taxledger
	
	020		: NEW OBJECT	: Ledger	
	
	030		: SET VALUE	: Name					: $$LocaleString:"Output  IGST Testing"
	040		: SET VALUE	: Parent				: $$LocaleString:"Duties & Taxes"
	050		: SET VALUE	: TAXTYPE				: $$LocaleString:"GST"
	060		: SET VALUE	: GSTDUTYHEAD           : $$LocaleString:"IGST"
	070		: SET VALUE	: RATEOFTAXCALCULATION  : $$LocaleString:"18"
